#!/usr/bin/env bash
set -euo pipefail

project_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${project_dir}"
[[ -f .env ]] || { echo "Missing .env." >&2; exit 1; }
set -a
. ./.env
set +a

[[ "${ROLLOUT_REVISION:-}" =~ ^[0-9a-f]{40}$ ]] || {
  echo "ROLLOUT_REVISION must be the full verified 40-character commit SHA." >&2
  exit 1
}

git fetch origin main
git merge-base --is-ancestor "${ROLLOUT_REVISION}" origin/main || {
  echo "Requested revision is not reachable from origin/main." >&2
  exit 1
}
git diff --quiet && git diff --cached --quiet || {
  echo "Refusing update with local tracked changes." >&2
  exit 1
}
git checkout --detach "${ROLLOUT_REVISION}"
./dev-ops/compose build --pull web
./dev-ops/compose up -d --force-recreate web
./dev-ops/compose ps
