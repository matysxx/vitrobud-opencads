#!/usr/bin/env bash
set -euo pipefail

project_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
user_dir="${XDG_CONFIG_HOME:-${HOME}/.config}/systemd/user"
mkdir -p "${user_dir}"
sed "s|@PROJECT_DIR@|${project_dir}|g" \
  "${project_dir}/dev-ops/systemd/vitrobud-opencads.service.in" \
  > "${user_dir}/vitrobud-opencads.service"
systemctl --user daemon-reload
echo "Installed vitrobud-opencads.service; enable with: systemctl --user enable --now vitrobud-opencads.service"
