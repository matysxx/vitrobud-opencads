#!/usr/bin/env bash
set -euo pipefail

project_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${project_dir}"

[[ -f .env ]] || { echo "Missing .env; copy .env.dist first." >&2; exit 1; }
set -a
# shellcheck disable=SC1091
source .env
set +a
: "${COMPOSE_PROVIDER_VERSION:?Set COMPOSE_PROVIDER_VERSION in .env}"
: "${COMPOSE_PROVIDER_SHA256:?Set COMPOSE_PROVIDER_SHA256 in .env}"

runtime_dir="${project_dir}/dev-ops/.runtime/podman-compose"
provider="${runtime_dir}/podman-compose"

if [[ -x "${provider}" ]] && [[ "$("${provider}" --version)" == *"${COMPOSE_PROVIDER_VERSION}"* ]]; then
  exit 0
fi

command -v curl >/dev/null 2>&1 || { echo "curl is required." >&2; exit 1; }
command -v sha256sum >/dev/null 2>&1 || { echo "sha256sum is required." >&2; exit 1; }
rm -rf "${runtime_dir}"
mkdir -p "${runtime_dir}"
download="${provider}.download"
curl -fsSL \
  "https://raw.githubusercontent.com/containers/podman-compose/v${COMPOSE_PROVIDER_VERSION}/podman_compose.py" \
  -o "${download}"
printf '%s  %s\n' "${COMPOSE_PROVIDER_SHA256}" "${download}" | sha256sum -c -
mv "${download}" "${provider}"
chmod 0755 "${provider}"
