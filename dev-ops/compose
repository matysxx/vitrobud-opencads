#!/usr/bin/env bash
set -euo pipefail

project_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${project_dir}"

[[ -f .env ]] || { echo "Missing .env; copy .env.dist first." >&2; exit 1; }
[[ -f src/.env ]] || { echo "Missing src/.env; copy src/.env.dist first." >&2; exit 1; }

if command -v podman >/dev/null 2>&1; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
  : "${OPENCADS_POD_NAME:?Set OPENCADS_POD_NAME in .env}"
  provider="${project_dir}/dev-ops/.runtime/podman-compose/bin/podman-compose"
  [[ -x "${provider}" ]] || {
    echo "Missing pinned podman-compose provider; run ./dev-ops/setup-compose-provider." >&2
    exit 1
  }
  exec "${provider}" --in-pod "${OPENCADS_POD_NAME}" "$@"
elif command -v docker >/dev/null 2>&1; then
  exec docker compose "$@"
else
  echo "Neither podman nor docker is installed." >&2
  exit 1
fi
